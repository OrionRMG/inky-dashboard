{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2024",
        "jsx": "react-jsx",
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strict": false,
        "sourceMap": true,
        "types": ["node"]
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}